{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm --prefix moved-bot-repo run dev",
    "dev:bot": "npm --prefix moved-bot-repo run start:bot",
    "start:server": "npm --prefix moved-bot-repo run start:server",
    "dev:full": "concurrently -n FRONT,BACKEND -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "lint:backend": "npm --prefix moved-bot-repo run lint",
    "check:tailwind-binding": "node -e \"require('@tailwindcss/oxide'); console.log('tailwind oxide binding ok')\""
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.0",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
