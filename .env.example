# ============================
# 환경 변수 예시 (.env.example)
# 복사해서 `.env`로 사용하세요. 민감한 값은 절대 레포지토리에 커밋하지 마세요.
# ============================

# GEMINI_API_KEY: 선택 - Gemini AI API 호출에 사용
GEMINI_API_KEY=""

# APP_URL: 앱이 호스팅되는 기본 URL (OAuth 콜백 등에 사용)
APP_URL=""

# ----------------------------
# Discord (봇)
# ----------------------------
# Discord bot token (Render/Github Secrets에 보관)
DISCORD_TOKEN=""
# (선택) 포럼 채널 ID, 클라이언트 ID/SECRET 등
DISCORD_FORUM_CHANNEL_ID=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# SESSION_SECRET: 세션/JWT 서명용 랜덤 문자열
SESSION_SECRET=""

# ----------------------------
# Supabase
# ----------------------------
# 서버/봇에서 사용 (비공개)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_ANON_KEY=""

# (선택) 직접 Postgres 접근이 필요하면 설정
DATABASE_URL=""

# 프론트엔드에서 사용 (Vercel에만 노출)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# ----------------------------
# 프론트엔드/서버 공통
# ----------------------------
# Vite: API 기본 경로 (예: https://api.example.com)
VITE_API_BASE=""

# NODE_ENV / PORT
NODE_ENV=development
PORT=3000

# ============================
# 보안 메모
# - `SUPABASE_SERVICE_ROLE_KEY`는 절대 클라이언트에 노출하지 마세요.
# - GitHub Actions에서는 Secrets로 관리하고 CI에서만 사용하세요.
# ============================
