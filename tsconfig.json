{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "test.ts",
    "test_scrape.ts"
  ],
  "exclude": [
    "moved-bot-repo/**",
    "src/app.ts",
    "src/scraper.ts",
    "src/supabase.ts",
    "src/backend/**",
    "src/middleware/**",
    "src/routes/**",
    "src/types.ts",
    "src/types/express.d.ts",
    "test.ts",
    "test_scrape.ts",
    "node_modules",
    "dist"
  ]
}
